# Copiar a .env.local y completar con los valores del proyecto Supabase
# (Project Settings → API en el dashboard de Supabase).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Datos reales de transferencia para la cuota (Cuotas → "Datos para
# transferir"). Son datos personales — no los pongas en el repo, solo acá y
# en las variables de entorno de Vercel.
NEXT_PUBLIC_PAYMENT_HOLDER=
NEXT_PUBLIC_PAYMENT_RUT=
NEXT_PUBLIC_PAYMENT_BANK=
NEXT_PUBLIC_PAYMENT_ACCOUNT_TYPE=
NEXT_PUBLIC_PAYMENT_EMAIL=
